    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=aws-0-ap-southeast-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.[YOUR_PROJECT_REF];Password=[YOUR_PASSWORD];SslMode=Require;TrustServerCertificate=true;"
  },
